# Copy this file to .env and fill in the key(s) for the backend you want to use.
# Module 3 auto-detects in this order: claude > openrouter > ollama > heuristic.
# Leave everything blank to fall back to the built-in deterministic heuristic
# (no LLM call, no cost — see src/llm_reasoning.py).

# ── Claude (Anthropic direct) ─────────────────────────────────────────────
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model defaults to claude-opus-4-7. Cheaper options: claude-haiku-4-5, claude-sonnet-4-6
# CLAUDE_MODEL=claude-opus-4-7

# ── OpenRouter (unified gateway for Claude, GPT, Gemini, DeepSeek, Llama, …) ─
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Default: a cheap, capable open-weight model. See https://openrouter.ai/models
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# ── Ollama (local, free) ──────────────────────────────────────────────────
# Install: https://ollama.com — then `ollama pull llama3.2` to fetch a model.
# Uncomment OLLAMA_HOST to enable. The /v1 suffix is added automatically.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── Override auto-detection ───────────────────────────────────────────────
# One of: claude | openrouter | ollama | heuristic
# LLM_BACKEND=
